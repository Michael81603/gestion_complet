DEBUG=True
SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# If DATABASE_URL is set (Neon, Supabase, Railway), it takes priority over DB_*.
# Example:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
DATABASE_URL=

# Fallback local configuration (used when DATABASE_URL is empty)
# Set USE_SQLITE=True for a quick local desktop/dev setup without PostgreSQL.
USE_SQLITE=False
DB_NAME=deliverpro
DB_USER=deliverpro_user
DB_PASSWORD=VotreMotDePasse123!
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:5500
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:5500

# Production WebSocket / realtime layer.
# Use the internal Redis/Valkey URL from your hosting provider in production.
REDIS_URL=

# Email notifications
# Local/dev: emails are printed in the Django terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=DeliverPro Finance <noreply@deliverpro.local>

# Production SMTP example (Gmail or SendGrid)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=DeliverPro Finance <your-email@gmail.com>

# Production recommendation (Render)
SECURE_SSL_REDIRECT=True
